{
  "manifest_version": 3,
  "name": "OmniAI Search",
  "version": "1.0.0",
  "description": "在搜索引擎结果旁显示主流 AI 的回答，支持豆包、ChatGPT、千问等。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*.doubao.com/*", 
    "https://kimi.moonshot.cn/*", 
    "https://*.kimi.com/*", 
    "https://chatgpt.com/*", 
    "https://chat.deepseek.com/*", 
    "https://tongyi.aliyun.com/*", 
    "https://*.qianwen.com/*",
    "https://yuanbao.tencent.com/*",
    "*://*.google.com/*",
    "*://*.claude.ai/*",
    "*://*.perplexity.ai/*",
    "*://copilot.microsoft.com/*",
    "*://grok.com/*",
    "*://*.chatglm.cn/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "OmniAI Search",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.doubao.com/*", 
        "https://kimi.moonshot.cn/*", 
        "https://*.kimi.com/*", 
        "https://chatgpt.com/*", 
        "https://chat.deepseek.com/*", 
        "https://tongyi.aliyun.com/*", 
        "https://*.qianwen.com/*",
        "https://yuanbao.tencent.com/*",
        "*://*.google.com/*",
        "*://*.claude.ai/*",
        "*://*.perplexity.ai/*",
        "*://copilot.microsoft.com/*",
        "*://grok.com/*",
        "*://*.chatglm.cn/*"
      ],
      "js": ["content/ai-inject.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.png",
        "icons/*.png",
        "icons/*.svg",
        "compare/*.html",
        "compare/*.css",
        "compare/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
